{
  "manifest_version": 3,
  "name": "Game Monitor Panel",
  "version": "1.0",
  "description": "遊戲監控面板 - 即時顯示HP/MP/位置/怪物",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://linh5web.win/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://linh5web.win/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
